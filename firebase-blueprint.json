{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the project" },
        "category": { "type": "string", "description": "Category of the project (interior, drawing, furniture)" },
        "coverImage": { "type": "string", "description": "URL of the cover image" },
        "shortDescription": { "type": "string", "description": "Short description of the project" },
        "details": {
          "type": "string",
          "description": "JSON stringified array of project details (title, description, images)"
        },
        "createdAt": { "type": "timestamp", "description": "When the project was created" }
      },
      "required": ["title", "category", "coverImage", "shortDescription", "details"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": { "$ref": "Project" },
      "description": "Portfolio projects"
    }
  }
}
